{
    "definitions": {
        "ActionType": {
            "properties": {
                "asset_name": {
                    "$ref": "#/definitions/GYTokenName"
                },
                "nft_recipient": {
                    "$ref": "#/definitions/GYAddress"
                },
                "policy_id": {
                    "$ref": "#/definitions/GYMintingPolicyId"
                },
                "target_value": {
                    "$ref": "#/definitions/GYValue"
                }
            },
            "required": [
                "policy_id",
                "asset_name",
                "target_value"
            ],
            "type": "object"
        },
        "AddWitAndSubmitParams": {
            "properties": {
                "tx_unsigned": {
                    "$ref": "#/definitions/GYTx"
                },
                "tx_wit": {
                    "$ref": "#/definitions/GYTxWitness"
                }
            },
            "required": [
                "tx_unsigned",
                "tx_wit"
            ],
            "type": "object"
        },
        "BulkDeriveItem": {
            "properties": {
                "asset_name": {
                    "$ref": "#/definitions/GYTokenName"
                },
                "policy_id": {
                    "$ref": "#/definitions/GYMintingPolicyId"
                }
            },
            "required": [
                "policy_id",
                "asset_name"
            ],
            "type": "object"
        },
        "BulkDeriveResponseItem": {
            "properties": {
                "address": {
                    "$ref": "#/definitions/GYAddress"
                },
                "asset_name": {
                    "$ref": "#/definitions/GYTokenName"
                },
                "policy_id": {
                    "$ref": "#/definitions/GYMintingPolicyId"
                },
                "script_hash": {
                    "$ref": "#/definitions/GYScriptHash"
                }
            },
            "required": [
                "policy_id",
                "asset_name",
                "address",
                "script_hash"
            ],
            "type": "object"
        },
        "DeriveResponse": {
            "properties": {
                "address": {
                    "$ref": "#/definitions/GYAddress"
                },
                "script_hash": {
                    "$ref": "#/definitions/GYScriptHash"
                }
            },
            "required": [
                "address",
                "script_hash"
            ],
            "type": "object"
        },
        "DeriveTraceResponse": {
            "properties": {
                "address": {
                    "$ref": "#/definitions/GYAddress"
                },
                "applied_script_bytes": {
                    "maximum": 9223372036854775807,
                    "minimum": -9223372036854775808,
                    "type": "integer"
                },
                "applied_script_cbor_hex": {
                    "type": "string"
                },
                "applied_script_hash": {
                    "type": "string"
                },
                "asset_name_hex": {
                    "$ref": "#/definitions/GYTokenName"
                },
                "cip14_fingerprint": {
                    "type": "string"
                },
                "params_cbor_hex": {
                    "type": "string"
                },
                "policy_id": {
                    "$ref": "#/definitions/GYMintingPolicyId"
                },
                "template_hash": {
                    "type": "string"
                },
                "toa_version": {
                    "type": "integer"
                }
            },
            "required": [
                "policy_id",
                "asset_name_hex",
                "cip14_fingerprint",
                "toa_version",
                "template_hash",
                "params_cbor_hex",
                "applied_script_cbor_hex",
                "applied_script_bytes",
                "applied_script_hash",
                "address"
            ],
            "type": "object"
        },
        "GYAddress": {
            "description": "Bech32-encoded Cardano address (addr_test1... on testnet, addr1... on mainnet)",
            "example": "00e1cbb80db89e292269aeb93ec15eb963dda5176b66949fe1c2a6a38d1b930e9f7add78a174a21000e989ff551366dcd127028cb2aa39f616",
            "format": "cbor hex",
            "maxLength": 114,
            "minLength": 114,
            "type": "string"
        },
        "GYMintingPolicyId": {
            "description": "This is the hash of a minting policy script.",
            "example": "ff80aaaf03a273b8f5c558168dc0e2377eea810badbae6eceefc14ef",
            "format": "hex",
            "maxLength": 56,
            "minLength": 56,
            "type": "string"
        },
        "GYScriptHash": {},
        "GYTokenName": {
            "description": "This is the name of a token.",
            "example": "476f6c64",
            "format": "hex",
            "maxLength": 64,
            "pattern": "[0-9a-fA-F]+",
            "type": "string"
        },
        "GYTx": {
            "description": "Transaction cbor hex string",
            "example": "",
            "type": "string"
        },
        "GYTxId": {
            "description": "Transaction id",
            "example": "a8d75b90a052302c1232bedd626720966b1697fe38de556c617c340233688935",
            "type": "string"
        },
        "GYTxOutRef": {
            "example": "4293386fef391299c9886dc0ef3e8676cbdbc2c9f2773507f1f838e00043a189#1",
            "format": "hex",
            "pattern": "[0-9a-fA-F]{64}#\"d+",
            "type": "string"
        },
        "GYTxWitness": {
            "type": "string"
        },
        "GYValue": {
            "additionalProperties": {
                "type": "integer"
            },
            "description": "A multi asset quantity, represented as map where each key represents an asset: policy ID and token name in hex concatenated by a dot.",
            "example": {
                "ff80aaaf03a273b8f5c558168dc0e2377eea810badbae6eceefc14ef.474f4c44": 101,
                "lovelace": 22
            },
            "type": "object"
        },
        "Interaction": {
            "properties": {
                "action": {
                    "$ref": "#/definitions/ActionType"
                },
                "recipient": {
                    "$ref": "#/definitions/GYAddress"
                },
                "userAddresses": {
                    "$ref": "#/definitions/UserAddresses"
                }
            },
            "required": [
                "action",
                "userAddresses"
            ],
            "type": "object"
        },
        "ServiceProbeStatus": {
            "properties": {
                "service": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "timestamp": {
                    "type": "string"
                },
                "version": {
                    "type": "string"
                }
            },
            "required": [
                "status",
                "service",
                "version",
                "timestamp"
            ],
            "type": "object"
        },
        "SubmitRequest": {
            "properties": {
                "tx_cbor_hex": {
                    "type": "string"
                }
            },
            "required": [
                "tx_cbor_hex"
            ],
            "type": "object"
        },
        "SubmitResponse": {
            "properties": {
                "tx_id": {
                    "$ref": "#/definitions/GYTxId"
                }
            },
            "required": [
                "tx_id"
            ],
            "type": "object"
        },
        "TxCborResponse": {
            "properties": {
                "tx_cbor_hex": {
                    "type": "string"
                }
            },
            "required": [
                "tx_cbor_hex"
            ],
            "type": "object"
        },
        "TxStatusResponse": {
            "properties": {
                "confirmed": {
                    "type": "boolean"
                },
                "tx_id": {
                    "$ref": "#/definitions/GYTxId"
                }
            },
            "required": [
                "tx_id",
                "confirmed"
            ],
            "type": "object"
        },
        "UserAddresses": {
            "properties": {
                "changeAddress": {
                    "$ref": "#/definitions/GYAddress"
                },
                "reservedCollateral": {
                    "example": "8282582004ffecdf5f3ced5c5c788833415bcbef26e3e21290fcebcf8216327e21569e420082583900e1cbb80db89e292269aeb93ec15eb963dda5176b66949fe1c2a6a38d1b930e9f7add78a174a21000e989ff551366dcd127028cb2aa39f6161a004c4b40",
                    "format": "cbor hex",
                    "pattern": "[0-9a-fA-F]+",
                    "type": "string"
                },
                "usedAddresses": {
                    "items": {
                        "$ref": "#/definitions/GYAddress"
                    },
                    "type": "array"
                }
            },
            "required": [
                "usedAddresses",
                "changeAddress"
            ],
            "type": "object"
        },
        "UtxoSummary": {
            "properties": {
                "datum_cbor_hex": {
                    "type": "string"
                },
                "datum_hash": {
                    "type": "string"
                },
                "ref": {
                    "$ref": "#/definitions/GYTxOutRef"
                },
                "value": {
                    "$ref": "#/definitions/GYValue"
                }
            },
            "required": [
                "ref",
                "value"
            ],
            "type": "object"
        },
        "UtxosResponse": {
            "properties": {
                "address": {
                    "$ref": "#/definitions/GYAddress"
                },
                "balance": {
                    "$ref": "#/definitions/GYValue"
                },
                "utxos": {
                    "items": {
                        "$ref": "#/definitions/UtxoSummary"
                    },
                    "type": "array"
                }
            },
            "required": [
                "address",
                "utxos",
                "balance"
            ],
            "type": "object"
        }
    },
    "info": {
        "description": "Token-Owned Addresses (TOA v1) reference HTTP API. Build deposits and spends, derive TOA addresses, list UTxOs, submit signed transactions.",
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        },
        "title": "TOA Demo API",
        "version": "0.1.0"
    },
    "paths": {
        "/health": {
            "get": {
                "description": "Returns the health status of the service",
                "produces": [
                    "application/json;charset=utf-8"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/ServiceProbeStatus"
                        }
                    }
                },
                "summary": "Health Check"
            }
        },
        "/ready": {
            "get": {
                "description": "Returns the readiness status of the service",
                "produces": [
                    "application/json;charset=utf-8"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/ServiceProbeStatus"
                        }
                    }
                },
                "summary": "Readiness Check"
            }
        },
        "/toa/derive": {
            "get": {
                "description": "Derive the TOA enterprise script address from (policy_id, asset_name).",
                "parameters": [
                    {
                        "in": "query",
                        "name": "policy_id",
                        "required": false,
                        "type": "string"
                    },
                    {
                        "in": "query",
                        "name": "asset_name",
                        "required": false,
                        "type": "string"
                    }
                ],
                "produces": [
                    "application/json;charset=utf-8"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/DeriveResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid `asset_name` or `policy_id`"
                    }
                },
                "summary": "Derive TOA address"
            }
        },
        "/toa/derive/bulk": {
            "post": {
                "consumes": [
                    "application/json;charset=utf-8"
                ],
                "description": "Derive multiple TOA addresses in a single request.",
                "parameters": [
                    {
                        "in": "body",
                        "name": "body",
                        "required": true,
                        "schema": {
                            "items": {
                                "$ref": "#/definitions/BulkDeriveItem"
                            },
                            "type": "array"
                        }
                    }
                ],
                "produces": [
                    "application/json;charset=utf-8"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "items": {
                                "$ref": "#/definitions/BulkDeriveResponseItem"
                            },
                            "type": "array"
                        }
                    },
                    "400": {
                        "description": "Invalid `body`"
                    }
                },
                "summary": "Derive TOA addresses in bulk"
            }
        },
        "/toa/derive/trace": {
            "get": {
                "description": "Returns the full TOA derivation trace (template hash, params CBOR, applied script CBOR + hash, fingerprint, address). Used by the developer panel to cross-check against the committed CIP test vectors. Accepts an optional toa_version query param (default 1).",
                "parameters": [
                    {
                        "in": "query",
                        "name": "policy_id",
                        "required": false,
                        "type": "string"
                    },
                    {
                        "in": "query",
                        "name": "asset_name",
                        "required": false,
                        "type": "string"
                    },
                    {
                        "in": "query",
                        "name": "toa_version",
                        "required": false,
                        "type": "integer"
                    }
                ],
                "produces": [
                    "application/json;charset=utf-8"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/DeriveTraceResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid `toa_version` or `asset_name` or `policy_id`"
                    }
                },
                "summary": "Derive TOA address with full trace"
            }
        },
        "/toa/spend": {
            "post": {
                "consumes": [
                    "application/json;charset=utf-8"
                ],
                "description": "Builds an unsigned tx that spends from a TOA. Returns hex-encoded CBOR for the wallet to sign. Request body is an 'Interaction' carrying the SpendToaAction and the wallet's UserAddresses.",
                "parameters": [
                    {
                        "in": "body",
                        "name": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/Interaction"
                        }
                    }
                ],
                "produces": [
                    "application/json;charset=utf-8"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/TxCborResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid `body`"
                    }
                },
                "summary": "Build a TOA spend transaction"
            }
        },
        "/toa/utxos": {
            "get": {
                "description": "Returns the UTxO set and aggregate balance at the given TOA address.",
                "parameters": [
                    {
                        "in": "query",
                        "name": "address",
                        "required": false,
                        "type": "string"
                    }
                ],
                "produces": [
                    "application/json;charset=utf-8"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/UtxosResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid `address`"
                    }
                },
                "summary": "List UTxOs at a TOA address"
            }
        },
        "/tx/sign": {
            "post": {
                "consumes": [
                    "application/json;charset=utf-8"
                ],
                "description": "Accepts the unsigned tx body and a wallet-produced witness set, combines them server-side via @makeSignedTransaction@, and returns the resulting hex-encoded CBOR. The client submits via the wallet (CIP-30 @submitTx@) — this keeps the backend off the chain-submission path.",
                "parameters": [
                    {
                        "in": "body",
                        "name": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/AddWitAndSubmitParams"
                        }
                    }
                ],
                "produces": [
                    "application/json;charset=utf-8"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/TxCborResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid `body`"
                    }
                },
                "summary": "Combine unsigned tx with wallet witness"
            }
        },
        "/tx/submit": {
            "post": {
                "consumes": [
                    "application/json;charset=utf-8"
                ],
                "description": "Submits a wallet-signed transaction CBOR to the network.",
                "parameters": [
                    {
                        "in": "body",
                        "name": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/SubmitRequest"
                        }
                    }
                ],
                "produces": [
                    "application/json;charset=utf-8"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/SubmitResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid `body`"
                    }
                },
                "summary": "Submit signed transaction"
            }
        },
        "/tx/tx-status/{txId}": {
            "get": {
                "description": "Returns whether a transaction has been confirmed on-chain. Single-attempt check designed for client-driven polling.",
                "parameters": [
                    {
                        "in": "path",
                        "name": "txId",
                        "required": true,
                        "type": "string"
                    }
                ],
                "produces": [
                    "application/json;charset=utf-8"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "schema": {
                            "$ref": "#/definitions/TxStatusResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid `txId`"
                    }
                },
                "summary": "Poll transaction status"
            }
        }
    },
    "swagger": "2.0"
}